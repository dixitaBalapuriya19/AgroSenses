# Frontend Environment Variables (Vite)
# Copy this file to .env.local for local development
# Set these in Vercel environment variables for production

# Backend API URL
# Development: http://localhost:8000/api
# Production: https://your-backend-url.onrender.com/api
VITE_API_URL=http://localhost:8000/api

# Optional hero illustration (Freepik/Storyset direct image URL)
# If set, this image is used instead of the fallback 3D model.
# Example: https://your-cdn.com/freepik-plant-3d.webp
VITE_HERO_FREEPIK_URL=

# Optional attribution link for the selected illustration
VITE_HERO_FREEPIK_CREDIT_URL=https://www.freepik.com/
